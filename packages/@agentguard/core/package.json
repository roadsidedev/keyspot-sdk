{
  "name": "@agentguard/core",
  "version": "2.0.0",
  "description": "Runtime security core for autonomous AI agents — Scanner, TaintEngine, Vault, PromptShield, AuditLogger",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scanner": {
      "types": "./dist/scanner.d.ts",
      "import": "./dist/scanner.js"
    },
    "./taint": {
      "types": "./dist/taint.d.ts",
      "import": "./dist/taint.js"
    },
    "./security": {
      "types": "./dist/security.d.ts",
      "import": "./dist/security.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    },
    "./compliance": {
      "types": "./dist/compliance.d.ts",
      "import": "./dist/compliance.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentguard/patterns": "workspace:*",
    "@agentguard/vault": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/roadsidedev/secret-shieldv1",
    "directory": "packages/@agentguard/core"
  },
  "keywords": ["agentguard", "ai-security", "secret-scanner", "taint-tracking", "vault"],
  "engines": {
    "node": ">=18.0.0"
  }
}
