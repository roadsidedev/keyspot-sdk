{
  "name": "@roadsidelab/keyspot-adapters",
  "version": "2.0.0",
  "description": "Production vector store adapters — Chroma, Pinecone, Qdrant, Weaviate, LanceDB, Milvus",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./chroma": {
      "types": "./dist/chroma.d.ts",
      "import": "./dist/chroma.js"
    },
    "./pinecone": {
      "types": "./dist/pinecone.d.ts",
      "import": "./dist/pinecone.js"
    },
    "./qdrant": {
      "types": "./dist/qdrant.d.ts",
      "import": "./dist/qdrant.js"
    },
    "./weaviate": {
      "types": "./dist/weaviate.d.ts",
      "import": "./dist/weaviate.js"
    },
    "./lancedb": {
      "types": "./dist/lancedb.d.ts",
      "import": "./dist/lancedb.js"
    },
    "./milvus": {
      "types": "./dist/milvus.d.ts",
      "import": "./dist/milvus.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@roadsidelab/keyspot-core": "workspace:*",
    "@pinecone-database/pinecone": "^3.0.0",
    "@qdrant/js-client-rest": "^1.0.0",
    "chromadb": "^3.4.0",
    "weaviate-ts-client": "^2.2.0",
    "lancedb": "^0.0.1",
    "@zilliz/milvus2-sdk-node": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/roadsidedev/secret-shieldv1",
    "directory": "packages/@agentguard/adapters"
  },
  "keywords": ["agentguard", "vector-store", "chroma", "pinecone", "qdrant", "weaviate", "lancedb", "milvus"],
  "engines": {
    "node": ">=18.0.0"
  }
}
