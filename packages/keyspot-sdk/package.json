{
  "name": "@roadsidelab/keyspot-sdk",
  "version": "2.0.0",
  "description": "Runtime security layer for autonomous AI agents — single SDK package",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./frameworks": {
      "types": "./dist/frameworks/index.d.ts",
      "import": "./dist/frameworks/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "bin": {
    "keyspot": "./dist/cli/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@roadsidelab/keyspot-core": "workspace:*",
    "@roadsidelab/keyspot-vault": "workspace:*",
    "@roadsidelab/keyspot-patterns": "workspace:*",
    "@roadsidelab/keyspot-adapters": "workspace:*",
    "@roadsidelab/keyspot-frameworks": "workspace:*",
    "@roadsidelab/keyspot-cli": "workspace:*"
  },
  "optionalDependencies": {
    "@pinecone-database/pinecone": "^4.0.0",
    "chromadb": "^2.0.0",
    "@qdrant/js-client-rest": "^1.12.0",
    "weaviate-ts-client": "^3.0.0",
    "lancedb": "^0.10.0",
    "@zilliz/milvus2-sdk-node": "^2.5.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@pinecone-database/pinecone": { "optional": true },
    "chromadb": { "optional": true },
    "@qdrant/js-client-rest": { "optional": true },
    "weaviate-ts-client": { "optional": true },
    "lancedb": { "optional": true },
    "@zilliz/milvus2-sdk-node": { "optional": true },
    "@aws-sdk/client-secrets-manager": { "optional": true }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/roadsidedev/keyspot-sdk"
  },
  "keywords": ["keyspot", "ai-security", "secret-scanner", "taint-tracking", "vault", "prompt-shield"],
  "engines": {
    "node": ">=18.0.0"
  }
}
