{
  "name": "@roadsidelab/keyspot-server",
  "version": "2.0.0",
  "description": "KeySpot HTTP server with rate limiting, auth, and x402 payment support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@roadsidelab/keyspot-core": "workspace:*",
    "@roadsidelab/keyspot-x402": "workspace:*",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/roadsidedev/keyspot-sdk",
    "directory": "packages/@keyspot/server"
  },
  "keywords": ["keyspot", "server", "api", "x402"],
  "engines": {
    "node": ">=18.0.0"
  }
}
