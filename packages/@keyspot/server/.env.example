# Database (Neon)
# Pooled connection for application queries
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/keyspot?sslmode=require"
# Direct connection for Prisma migrations (no pooler)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/keyspot?sslmode=require"

# Auth
JWT_SECRET="change-this-to-a-32-char-random-string"
APP_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_FREE="price_free"
STRIPE_PRICE_PRO="price_pro_monthly"
STRIPE_PRICE_ENTERPRISE="price_enterprise_monthly"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Redis
REDIS_URL="redis://localhost:6379"

# Email (SMTP or Resend)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="user"
# SMTP_PASS="pass"
# RESEND_API_KEY="re_..."
EMAIL_FROM="KeySpot <noreply@keyspot.dev>"

# Server
PORT=3000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3001"

# x402 (optional crypto payments)
# ENABLE_X402="false"
# X402_NETWORK="base"
# PAY_TO_ADDRESS="0x..."
# X402_PRICE="0.0001"
# BASE_RPC_URL="https://mainnet.base.org"
