generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
  OWNER
}

enum Tier {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  emailVerified   DateTime?
  passwordHash    String?
  name            String?
  image           String?
  role            Role           @default(USER)
  organizationId  String?
  organization    Organization?  @relation("OrganizationMembers", fields: [organizationId], references: [id])
  ownedOrganization Organization? @relation("OrganizationOwner")
  apiKeys         ApiKey[]
  subscription    Subscription?
  usageEvents     UsageEvent[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([email])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String   @unique
  owner     User     @relation("OrganizationOwner", fields: [ownerId], references: [id])
  members   User[]   @relation("OrganizationMembers")
  apiKeys   ApiKey[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id          String         @id @default(cuid())
  prefix      String
  keyHash     String
  name        String
  scopes      String[]
  rateLimit   Int            @default(1000)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId       String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  usageEvents UsageEvent[]
  createdAt   DateTime       @default(now())
  revokedAt   DateTime?

  @@index([userId])
  @@index([prefix])
}

model Subscription {
  id                      String             @id @default(cuid())
  stripeCustomerId        String             @unique
  stripeSubscriptionId    String?            @unique
  stripePriceId           String
  stripeCurrentPeriodEnd  DateTime
  status                  SubscriptionStatus @default(INCOMPLETE)
  tier                    Tier               @default(FREE)
  cancelAtPeriodEnd       Boolean            @default(false)
  userId                  String             @unique
  user                    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
}

enum RevenueSource {
  SUBSCRIPTION
  X402
}

enum AgentStatus {
  ACTIVE
  SUSPENDED
  MIGRATED
}

model AgentIdentity {
  id              String      @id @default(cuid())
  agentId         String
  agentRegistry   String
  walletAddress   String      @unique
  configSnapshot  Json?
  tier            Tier        @default(FREE)
  status          AgentStatus @default(ACTIVE)
  lastActiveAt    DateTime?
  usageEvents     UsageEvent[]
  accessGrants    X402AccessGrant[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([agentId, agentRegistry])
  @@index([walletAddress])
}

model X402AccessGrant {
  id              String       @id @default(cuid())
  agentIdentityId String?
  agentIdentity   AgentIdentity? @relation(fields: [agentIdentityId], references: [id], onDelete: SetNull)
  walletAddress   String       @unique
  credit          BigInt       @default(0)
  expiry          DateTime
  endpoint        String
  freeQuotaUsed   Int          @default(0)
  freeQuotaReset  DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([walletAddress])
  @@index([expiry])
}

model UsageEvent {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeyId        String?
  apiKey          ApiKey?       @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  agentIdentityId String?
  agentIdentity   AgentIdentity? @relation(fields: [agentIdentityId], references: [id], onDelete: SetNull)
  revenueSource   RevenueSource @default(SUBSCRIPTION)
  x402Wallet      String?
  endpoint        String
  method          String
  statusCode      Int
  latencyMs       Int
  metadata        Json?
  timestamp       DateTime      @default(now()) @db.Timestamptz(6)

  @@index([userId, timestamp])
  @@index([apiKeyId, timestamp])
  @@index([agentIdentityId, timestamp])
  @@index([revenueSource])
}

model ResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tokenHash])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tokenHash])
  @@index([expiresAt])
}
