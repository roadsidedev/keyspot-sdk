{
  "name": "@roadsidelab/keyspot-patterns",
  "version": "2.0.0",
  "description": "Extensible secret detection patterns for KeySpot — 40+ built-in patterns with Aho-Corasick fast matching",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
