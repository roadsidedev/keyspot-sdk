  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/roadsidedev/keyspot-sdk",
    "directory": "packages/@keyspot/patterns"
  },
  "keywords": ["keyspot", "secret-patterns", "regex", "detection"],
  "engines": {
