{
  "name": "@roadsidelab/keyspot-core",
  "version": "2.0.0",
  "description": "KeySpot SDK core — runtime security for autonomous AI agents (Scanner, TaintEngine, Vault, PromptShield, AuditLogger). Part of @roadsidelab/keyspot-sdk.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scanner": {
      "types": "./dist/scanner.d.ts",
      "import": "./dist/scanner.js"
    },
    "./taint": {
      "types": "./dist/taint.d.ts",
      "import": "./dist/taint.js"
    },
    "./security": {
      "types": "./dist/security.d.ts",
      "import": "./dist/security.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    },
    "./compliance": {
      "types": "./dist/compliance.d.ts",
      "import": "./dist/compliance.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry.d.ts",
      "import": "./dist/telemetry.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@roadsidelab/keyspot-patterns": "workspace:*",
    "@roadsidelab/keyspot-vault": "workspace:*",
    "@roadsidelab/keyspot-adapters": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/roadsidedev/keyspot-sdk",
    "directory": "packages/@keyspot/core"
  },
  "keywords": ["keyspot", "ai-security", "secret-scanner", "taint-tracking", "vault"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
