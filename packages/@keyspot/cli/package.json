{
  "name": "@roadsidelab/keyspot-cli",
  "version": "2.0.0",
  "description": "KeySpot SDK CLI — scan files, install pre-commit hooks, and integrate with CI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "keyspot": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@roadsidelab/keyspot-core": "workspace:*",
    "@roadsidelab/keyspot-patterns": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/roadsidelab/keyspot-sdk",
    "directory": "packages/@keyspot/cli"
  },
  "keywords": ["keyspot", "cli", "secret-scanner", "pre-commit"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
