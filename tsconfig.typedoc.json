{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@roadsidelab/keyspot-core": ["./packages/@keyspot/core/src"],
      "@roadsidelab/keyspot-core/*": ["./packages/@keyspot/core/src/*"],
      "@roadsidelab/keyspot-patterns": ["./packages/@keyspot/patterns/src"],
      "@roadsidelab/keyspot-vault": ["./packages/@keyspot/vault/src"],
      "@roadsidelab/keyspot-adapters": ["./packages/@keyspot/adapters/src"],
      "@roadsidelab/keyspot-adapters/*": ["./packages/@keyspot/adapters/src/*"],
      "@roadsidelab/keyspot-x402": ["./packages/@keyspot/x402/src"],
      "@roadsidelab/keyspot-server": ["./packages/@keyspot/server/src/app.ts"],
      "@roadsidelab/keyspot-server/*": ["./packages/@keyspot/server/src/*"],
      "@roadsidelab/keyspot-frameworks": ["./packages/@keyspot/frameworks/src"],
      "@roadsidelab/keyspot-cli": ["./packages/@keyspot/cli/src"]
    }
  },
  "exclude": ["**/*.test.ts", "**/tests/**", "benchmark.ts", "test-v2.ts", "vitest.config.ts", "apps/web", "keyspot-sdk/apps/web"]
}
