{
  "name": "@roadsidelab/keyspot-sdk",
  "version": "2.0.0",
  "private": true,
  "description": "KeySpot SDK monorepo — runtime security layer for autonomous AI agents. Published as @roadsidelab/keyspot-sdk.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint packages/*/src/**/*.ts",
    "lint:fix": "eslint packages/*/src/**/*.ts --fix",
    "typecheck": "tsc -b",
    "docs": "typedoc",
    "docs:serve": "npx serve docs/api",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "publish:npm": "pnpm publish -r --access public",
    "setup": "pnpm docker:up && pnpm db:setup && pnpm dev",
    "docker:up": "docker compose up -d postgres redis",
    "docker:down": "docker compose down",
    "docker:stripe": "docker compose run --rm stripe-cli",
    "db:setup": "pnpm --filter @roadsidelab/keyspot-server db:setup",
    "db:reset": "pnpm --filter @roadsidelab/keyspot-server db:reset",
    "start:server": "pnpm --filter @roadsidelab/keyspot-server dev",
    "start:web": "pnpm --filter keyspot-web dev --port 3001",
    "dev": "concurrently -n api,web -c cyan,magenta \"pnpm start:server\" \"pnpm start:web\""
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@x402/core": "^2.14.0",
    "@x402/evm": "^2.14.0",
    "@x402/express": "^2.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.11.1",
    "jose": "^5.9.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^3.22.0"
  }
}
